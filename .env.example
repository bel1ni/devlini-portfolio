# === Fase 2: painel self-serve de anúncios ===
# Sem essas variáveis o site funciona no modo Fase 1 (CTA de anúncio por e-mail).
# Adicione na Vercel: Settings → Environment Variables (Production) e redeploye.

# Postgres via Supabase:
#   1. SQL Editor → cole e rode scripts/init-db.sql (uma vez)
#   2. Painel do Supabase → Connect → Connection String → "Transaction pooler"
#      (porta 6543 — o código já usa prepare:false, exigido pelo pooler)
#   3. Adicione na Vercel: Settings → Environment Variables → Production
# Formato: postgresql://postgres.[PROJECT-REF]:[SENHA]@[REGIAO].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Stripe (https://dashboard.stripe.com/apikeys)
# ADIADO: requer conta Stripe. Sem essas chaves o site segue no modo Fase 1
# (CTA de anúncio por e-mail) — nada quebra.
STRIPE_SECRET_KEY=
# Webhook: Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://devlini.com/api/stripe-webhook
#   Evento: checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# Senha do painel /admin?key=... (invente uma string longa e aleatória)
ADMIN_SECRET=

# Vercel Blob para as imagens dos anúncios (Storage → Create → Blob).
# Sem ele, as imagens são salvas inline no banco (funciona, mas Blob é melhor).
BLOB_READ_WRITE_TOKEN=

# Opcional: e-mails transacionais via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM="Link Hub <onboarding@resend.dev>"
ADMIN_EMAIL=mariane.r.belini@gmail.com

# Já tem default no código; sobrescreva se necessário
# NEXT_PUBLIC_SITE_URL=https://devlini.com
